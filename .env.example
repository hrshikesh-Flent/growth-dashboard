# Hawkeye (Twenty CRM at crm.flent.in) — required
HAWKEYE_TOKEN=eyJ...your-twenty-crm-api-key

# Server port — defaults to 4000 if not set
PORT=4000

# Meta Ads — optional, enables Meta spend section
META_TOKEN=your_meta_access_token_here
META_ACCOUNT_ID=your_meta_ad_account_id

# Google Ads OAuth2 — optional, enables Google Ads spend section
GADS_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GADS_CLIENT_SECRET=GOCSPX-your_client_secret
GADS_REFRESH_TOKEN=1//your_refresh_token
GADS_DEVELOPER_TOKEN=your_developer_token
GADS_CUSTOMER_ID=your_customer_id
GADS_LOGIN_CUSTOMER_ID=your_mcc_login_customer_id
